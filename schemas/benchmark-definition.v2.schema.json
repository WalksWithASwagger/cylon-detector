{
  "$id": "https://cylon-detector.org/schemas/benchmark-definition.v2.schema.json",
  "title": "MAC Consciousness Bench Definition v2",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "mac-benchmark-definition/v2"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$"
    },
    "lifecycle": {
      "type": "string",
      "enum": [
        "draft",
        "provisional",
        "published",
        "retired"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "authorship": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "identifier": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "name",
          "role"
        ],
        "additionalProperties": false
      }
    },
    "sourceUrls": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "demands": {
      "minItems": 5,
      "maxItems": 5,
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "explanation",
          "mechanism",
          "novelPrediction",
          "falsifier",
          "measurableWitness"
        ]
      }
    },
    "challenges": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$"
          },
          "integrityDigest": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "required": [
          "id",
          "version",
          "integrityDigest"
        ],
        "additionalProperties": false
      }
    },
    "integrityDigest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "version",
    "lifecycle",
    "title",
    "description",
    "authorship",
    "sourceUrls",
    "createdAt",
    "demands",
    "challenges",
    "integrityDigest"
  ],
  "additionalProperties": false
}

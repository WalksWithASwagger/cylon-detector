{
  "$id": "https://cylon-detector.org/schemas/benchmark-definition.v1.schema.json",
  "title": "MAC Consciousness Bench Definition v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "mac-benchmark-definition/v1"
    },
    "id": {
      "type": "string",
      "const": "mac-lab-001"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "const": "provisional"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "authors": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "name",
          "role"
        ],
        "additionalProperties": false
      }
    },
    "sourceUrls": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "demands": {
      "minItems": 5,
      "maxItems": 5,
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "explanation",
          "mechanism",
          "novelPrediction",
          "falsifier",
          "measurableWitness"
        ]
      }
    },
    "challenges": {
      "minItems": 3,
      "maxItems": 3,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "provenance-flip",
              "synesthesia",
              "blindsight"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "shortName": {
            "type": "string",
            "minLength": 1
          },
          "phenomenon": {
            "type": "string",
            "minLength": 1
          },
          "adversarialPrompt": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "empiricalAnchors": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "doi": {
                  "type": "string"
                },
                "url": {
                  "type": "string",
                  "format": "uri"
                }
              },
              "required": [
                "label",
                "url"
              ],
              "additionalProperties": false
            }
          },
          "demands": {
            "minItems": 5,
            "maxItems": 5,
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "explanation",
                "mechanism",
                "novelPrediction",
                "falsifier",
                "measurableWitness"
              ]
            }
          }
        },
        "required": [
          "id",
          "name",
          "shortName",
          "phenomenon",
          "adversarialPrompt",
          "rationale",
          "empiricalAnchors",
          "demands"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "version",
    "status",
    "title",
    "description",
    "authors",
    "sourceUrls",
    "createdAt",
    "demands",
    "challenges"
  ],
  "additionalProperties": false
}

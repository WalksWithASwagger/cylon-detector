{
  "$id": "https://cylon-detector.org/schemas/review-bundle.v1.schema.json",
  "title": "Review Bundle v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "review-bundle/v1"
    },
    "bundleId": {
      "type": "string",
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "packet": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "blind-review-packet/v1"
        },
        "packetId": {
          "type": "string",
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
        },
        "alias": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        },
        "blinding": {
          "type": "string",
          "const": "partial"
        },
        "blindingNotice": {
          "type": "string",
          "minLength": 1
        },
        "benchmark": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            },
            "version": {
              "type": "string",
              "minLength": 1
            },
            "integrityDigest": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          },
          "required": [
            "id",
            "version",
            "integrityDigest"
          ],
          "additionalProperties": false
        },
        "sourceBindingDigest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "receiptBindingDigest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "commitments": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "blindClaimId": {
                "type": "string",
                "minLength": 1
              },
              "challengeId": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
              },
              "demand": {
                "type": "string",
                "minLength": 1
              },
              "commitment": {
                "type": "string",
                "minLength": 1
              },
              "evidenceBindings": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "redactedLabel": {
                      "type": "string",
                      "const": "Evidence redacted until provenance reveal"
                    },
                    "evidenceDigest": {
                      "type": "string",
                      "pattern": "^[a-f0-9]{64}$"
                    }
                  },
                  "required": [
                    "redactedLabel",
                    "evidenceDigest"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "required": [
              "blindClaimId",
              "challengeId",
              "demand",
              "commitment",
              "evidenceBindings"
            ],
            "additionalProperties": false
          }
        },
        "integrityDigest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "required": [
        "schemaVersion",
        "packetId",
        "alias",
        "createdAt",
        "blinding",
        "blindingNotice",
        "benchmark",
        "sourceBindingDigest",
        "receiptBindingDigest",
        "commitments",
        "integrityDigest"
      ],
      "additionalProperties": false
    },
    "contributions": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "schemaVersion": {
            "type": "string",
            "const": "review-contribution/v1"
          },
          "contributionId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
          },
          "packetIntegrityDigest": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "reviewerAlias": {
            "type": "string",
            "minLength": 1
          },
          "blindLock": {
            "type": "object",
            "properties": {
              "lockedAt": {
                "type": "string",
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
              },
              "calls": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "blindClaimId": {
                      "type": "string",
                      "minLength": 1
                    },
                    "judgment": {
                      "type": "string",
                      "enum": [
                        "supported",
                        "strained",
                        "unsupported",
                        "insufficient_evidence"
                      ]
                    },
                    "confidence": {
                      "type": "string",
                      "enum": [
                        "low",
                        "medium",
                        "high"
                      ]
                    },
                    "responseTimeMs": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    "reason": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "blindClaimId",
                    "judgment",
                    "confidence",
                    "responseTimeMs",
                    "reason"
                  ],
                  "additionalProperties": false
                }
              },
              "integrityDigest": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            },
            "required": [
              "lockedAt",
              "calls",
              "integrityDigest"
            ],
            "additionalProperties": false
          },
          "provenanceReveal": {
            "type": "object",
            "properties": {
              "envelopeIntegrityDigest": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "revealedAt": {
                "type": "string",
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
              },
              "secondCalls": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "blindClaimId": {
                      "type": "string",
                      "minLength": 1
                    },
                    "judgment": {
                      "type": "string",
                      "enum": [
                        "supported",
                        "strained",
                        "unsupported",
                        "insufficient_evidence"
                      ]
                    },
                    "confidence": {
                      "type": "string",
                      "enum": [
                        "low",
                        "medium",
                        "high"
                      ]
                    },
                    "responseTimeMs": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    "reason": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "blindClaimId",
                    "judgment",
                    "confidence",
                    "responseTimeMs",
                    "reason"
                  ],
                  "additionalProperties": false
                }
              },
              "deltas": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "blindClaimId": {
                      "type": "string",
                      "minLength": 1
                    },
                    "changed": {
                      "type": "boolean"
                    },
                    "firstJudgment": {
                      "type": "string",
                      "enum": [
                        "supported",
                        "strained",
                        "unsupported",
                        "insufficient_evidence"
                      ]
                    },
                    "secondJudgment": {
                      "type": "string",
                      "enum": [
                        "supported",
                        "strained",
                        "unsupported",
                        "insufficient_evidence"
                      ]
                    },
                    "firstConfidence": {
                      "type": "string",
                      "enum": [
                        "low",
                        "medium",
                        "high"
                      ]
                    },
                    "secondConfidence": {
                      "type": "string",
                      "enum": [
                        "low",
                        "medium",
                        "high"
                      ]
                    },
                    "firstResponseTimeMs": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    "secondResponseTimeMs": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    "humanReason": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "blindClaimId",
                    "changed",
                    "firstJudgment",
                    "secondJudgment",
                    "firstConfidence",
                    "secondConfidence",
                    "firstResponseTimeMs",
                    "secondResponseTimeMs",
                    "humanReason"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "required": [
              "envelopeIntegrityDigest",
              "revealedAt",
              "secondCalls",
              "deltas"
            ],
            "additionalProperties": false
          },
          "integrityDigest": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "required": [
          "schemaVersion",
          "contributionId",
          "packetIntegrityDigest",
          "reviewerAlias",
          "blindLock",
          "integrityDigest"
        ],
        "additionalProperties": false
      }
    },
    "disagreements": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "blindClaimId": {
            "type": "string",
            "minLength": 1
          },
          "calls": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "reviewerAlias": {
                  "type": "string",
                  "minLength": 1
                },
                "judgment": {
                  "type": "string",
                  "enum": [
                    "supported",
                    "strained",
                    "unsupported",
                    "insufficient_evidence"
                  ]
                },
                "confidence": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high"
                  ]
                },
                "reason": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "reviewerAlias",
                "judgment",
                "confidence",
                "reason"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "blindClaimId",
          "calls"
        ],
        "additionalProperties": false
      }
    },
    "dissentNotice": {
      "type": "string",
      "const": "Calls are preserved independently. No score, average, or synthetic consensus is produced."
    },
    "integrityDigest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "required": [
    "schemaVersion",
    "bundleId",
    "createdAt",
    "packet",
    "contributions",
    "disagreements",
    "dissentNotice",
    "integrityDigest"
  ],
  "additionalProperties": false
}

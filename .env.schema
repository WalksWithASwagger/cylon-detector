# @defaultRequired=infer @defaultSensitive=false
# ---

# Selects deterministic local analysis or the live OpenAI route.
# @public @type=enum(mock, live)
MAC_ANALYSIS_MODE=mock

# Global server analysis shutdown. Local browser rehearsal is unaffected.
MAC_LIVE_ANALYSIS_ENABLED=false

# The model used only when MAC_ANALYSIS_MODE=live.
# @public
OPENAI_MODEL=gpt-5.6-sol

# Required at runtime only for live analysis. Keep the value in a gitignored local override or secret provider.
# @sensitive @optional @type=string(startsWith=sk-)
OPENAI_API_KEY=

# Required to enable /api/analyze. The route returns 503 while unset and 401 without a matching bearer token.
# Used only by the non-production static invite policy.
# @sensitive @optional @type=string(minLength=24)
MAC_BENCH_ACCESS_TOKEN=

# Selects fail-closed invite access, a local static code, or the Upstash production adapter.
# @public @type=enum(disabled, static, upstash)
MAC_INVITE_POLICY=disabled

# Keyed hashing secret for invite codes and IP addresses. Never expose this to the browser.
# @sensitive @optional @type=string(minLength=32)
MAC_INVITE_HASH_PEPPER=

# Default local-static run allowance. Upstash invitations carry their own maxRuns value.
# @public @type=number
MAC_INVITE_MAX_RUNS=20

# Default per-paper character allowance for local-static analysis.
# @public @type=number
MAC_INVITE_MAX_INPUT_CHARACTERS=200000

# Per-IP live-analysis attempts allowed in each ten-minute window.
# @public @type=number
MAC_INVITE_IP_REQUESTS=10

# Injected by the Upstash Redis Vercel Marketplace integration.
# @sensitive @optional @type=url
UPSTASH_REDIS_REST_URL=

# Injected by the Upstash Redis Vercel Marketplace integration.
# @sensitive @optional
UPSTASH_REDIS_REST_TOKEN=

# When true, the browser calls /api/analyze. When false, it runs the deterministic local apparatus rehearsal.
# @public @type=boolean
VITE_USE_ANALYSIS_API=false

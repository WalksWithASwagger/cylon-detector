{
  "name": "cylon-detector",
  "private": true,
  "version": "0.2.0-beta.1",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "dev:full": "npx --yes vercel@56.4.0 dev --listen 8080",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "posttest": "npm run test:agentic",
    "test:agentic": "python3 -m unittest discover -s test/agentic -p 'test_*.py'",
    "test:watch": "vitest",
    "test:e2e": "playwright test && npm run validate:field-evidence",
    "type-check": "tsc --noEmit",
    "generate:schemas": "tsx scripts/generate-schemas.ts",
    "generate:fixtures": "tsx scripts/generate-demo-artifact.ts",
    "generate:collaboration-fixtures": "tsx fixtures/collaboration/synthetic-collaboration.ts",
    "validate:data": "tsx scripts/validate-data.ts",
    "validate:registry": "tsx scripts/validate-benchmark-registry.ts",
    "validate:schemas": "tsx scripts/validate-schemas.ts",
    "validate:build": "tsx scripts/validate-build.ts",
    "validate:field-evidence": "tsx scripts/validate-field-evidence.ts",
    "validate:collaboration": "tsx scripts/validate-collaboration-packet.ts",
    "verify:receipt": "tsx scripts/verify-canonical-receipt.ts",
    "test:conformance": "vitest run test/conformance",
    "verify": "npm run type-check && npm run validate:data && npm run validate:registry && npm run validate:schemas && npm run validate:collaboration && npm test && npm run build && npm run validate:build",
    "vercel-build": "npm run generate-sitemap && npm run build",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "i18n-check": "node scripts/i18n-check.js"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "22.20.1",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "sass": "1.101.0",
    "tsx": "4.23.1",
    "typescript": "5.8.3",
    "varlock": "1.11.0",
    "vite-plugin-html-inject": "1.1.2",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "echarts": "6.1.0",
    "mixpanel-browser": "2.71.0",
    "openai": "6.48.0",
    "pdfjs-dist": "6.1.200",
    "vite": "6.4.3",
    "vite-tsconfig-paths": "5.1.4",
    "zod": "4.4.3"
  }
}
